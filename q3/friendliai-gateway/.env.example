# ── Mock / local testing (no real API needed) ─────────────────────────────
GW_UPSTREAM_BASE_URL=http://localhost:9000/v1
GW_UPSTREAM_API_KEY=no-key
GW_SUMMARISER_BASE_URL=http://localhost:9000/v1
GW_SUMMARISER_API_KEY=no-key
GW_SUMMARISER_MODEL=gpt-4o-mini   # mock upstream ignores this

# ── Real upstream (FriendliAI / OpenAI / vLLM / etc.) ─────────────────────
# GW_UPSTREAM_BASE_URL=https://api.friendli.ai/v1
# GW_UPSTREAM_API_KEY=your-friendli-key
# GW_SUMMARISER_BASE_URL=https://api.openai.com/v1
# GW_SUMMARISER_API_KEY=your-openai-key
# GW_SUMMARISER_MODEL=gpt-4o-mini

# ── FriendliAI dedicated endpoint (no model field in request body) ─────────
# GW_UPSTREAM_BASE_URL=https://api.friendli.ai/dedicated
# GW_UPSTREAM_API_KEY=your-friendli-token
# GW_UPSTREAM_ENDPOINT_ID=your-endpoint-id   # e.g. depjs3iq370hmqt
# GW_SUMMARISER_BASE_URL=https://api.friendli.ai/dedicated
# GW_SUMMARISER_API_KEY=your-friendli-token
# GW_SUMMARISER_MODEL=your-endpoint-id

# ── Gateway behaviour ──────────────────────────────────────────────────────
GW_HOST=0.0.0.0
GW_PORT=8000
GW_UPSTREAM_TIMEOUT_S=120.0
GW_SUMMARISER_TIMEOUT_S=30.0
GW_MAX_REASONING_TOKENS=16384
GW_ENABLE_PROMPT_SUMMARY=true
GW_ENABLE_REASONING_SUMMARY=true
GW_MAX_RETRIES=2
GW_LOG_LEVEL=INFO

# ── CORS (comma-separated origins, * = allow all) ─────────────────────────
# GW_ALLOWED_ORIGINS=https://yourapp.com,https://staging.yourapp.com
